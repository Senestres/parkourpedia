---
layout: layouts/base.njk
---
{# Only include the syntax highlighter CSS on blog posts, included with the CSS per-page bundle #}
<style>{% include "node_modules/prismjs/themes/prism-okaidia.css" %}</style>
<style>{% include "css/prism-diff.css" %}</style>

{# Metadata for pagefind filters #}
	<meta data-pagefind-filter="catégorie:{{category or "aucune"}}">
{# 	<meta data-pagefind-filter="Forme caractéristique:{{fc or "aucune"}}"> #}
	{%- for f in fc %}
	<meta data-pagefind-filter="forme caractéristique:{{f}}">
	{%- endfor %}

<h1>{{ title }}</h1>
<div><b>Formes caractéristiques:</b> {% for f in fc %} {{f}}{%- if not loop.last %}, {% endif %} {% endfor %}</div>

{% if coverImage %}
	<img src="../img/{{coverImage}}" alt="This is a cover image">
{% endif %}
{# <h2>Video</h2> or img ? #}

<h2>Description</h2>

<article data-pagefind-body>
	{{ content | safe }}
</article>

{# Check if there are variations and foundations #}
{% set foundations = [] %}
{% set variations = [] %}

{%- for move in collections.mouvement %}
  {% if move.data.prerequis %}
    {% for requis in prerequis %}
      {% if move.data.title | slugify == requis | slugify %}
        {% set foundations = foundations.concat([move]) %}
      {% endif %}
    {% endfor %}
	{% for requis in move.data.prerequis %}
      {% if title | slugify == requis | slugify %}
        {% set variations = variations.concat([move]) %}
      {% endif %}
    {% endfor %}
  {% endif %}
{%- endfor %}


{# build list of variations #}
{% if foundations | length %}
	<h2>Prérequis</h2>
	{% set postslist = foundations %}
	{% include "postslist.njk" %}
{% endif %}

{# build list of variations #}
{% if variations | length %}
  <h2>Variations</h2>
{% set postslist = variations %}
{% include "postslist.njk" %}
{% endif %}

{# Cover images used to work but not anymore
{% set imageUrl %}../img/{{move.data.coverImage}}{% endset %}
but now 
 #}

<div class="post-metadata">
	<div><b>Date: </b><time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate("dd LLLL yyyy") }}</time></div>
	{% if author %}
		<div><b>Auteur: </b>{{author}}</div>
	{% endif %}
	<div><b>Tags: </b>
		{%- for tag in tags | filterTagList %}
		{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
		<a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>{%- if not loop.last %}, {% endif %}
		{%- endfor %}
	</div>
</div>














