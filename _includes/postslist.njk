<ol reversed class="postlist-row" style="--postlist-index: {{ (postslistCounter or postslist.length) + 1 }}">
	{%- for post in postslist | reverse %}
		<li class="postlist-card" >
			<a href="{{ post.url }}">
				{% set imageUrl %}/img/{{post.data.coverImage}}{% endset %}
				<div class="card-header">
					<div class="card-overlay">{% if post.data.title %}{{ post.data.title }}{% else %} <code>{{ post.url }}</code>{% endif %}</div>
					{# If need some flexibility for cover images, change something here #}
					{# {% if post.data.coverImage %}<img class="card-img" src="{{ imageUrl }}" alt="">{% endif %} #}

					{% if post.data.video %} {# Should be adapted if video =/= youtube #}
						<img class="card-img" src="https://img.youtube.com/vi/{{ post.data.video }}/hqdefault.jpg" alt="youtube thumbnail">
					{% endif %}
					
				</div>
			</a>
		</li>
	{%- endfor %}
</ol>