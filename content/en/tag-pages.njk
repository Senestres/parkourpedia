---
eleventyComputed:
  title: "Tagged '{{ tag }}'"
  lang: "en"
  permalink: "/en/tags/{{ tag | slugify }}/"
eleventyExcludeFromCollections: true
pagination:
  data: "collections"
  size: 1
  alias: "tag"
  filter: ["all", "posts"]
---

{% set fc = i18n.formesCaracteristiques[tag] %}

<h1>“{{ fc[page.lang].short | lower or tag | lower }}”</h1>

{# This should get the long name of a FC #}
 {{ fc[page.lang].long }} {{ fc.emoji }}

{% set postslist = collections[ tag ] | pageLang %}
{% include "postslist.njk" %}

<p>See <a href="{{ "/tags/" | locale_url }}">all tags</a>.</p>
