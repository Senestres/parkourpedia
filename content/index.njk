---js
const eleventyNavigation = {
	key: "Home",
	order: 1
};

const numberOfLatestPostsToShow = 3;
---


<h1>Explorer</h1>
{# Search #}
{# Script #}
<link href="/pagefind/pagefind-component-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-component-ui.js" type="module"></script>
<pagefind-config faceted preload></pagefind-config>

<pagefind-filter-pane open="Forme caractéristique, Catégorie"></pagefind-filter-pane>
<pagefind-input placeholder="Recherche"></pagefind-input>
<pagefind-summary></pagefind-summary>
<pagefind-results></pagefind-results>

{% set postsCount = collections.posts | length %}
{% set latestPostsCount = postsCount | min(numberOfLatestPostsToShow) %}
<h1>Contenu récent</h1>

{% set postslist = collections.posts | head(-1 * numberOfLatestPostsToShow) %}
{% set postslistCounter = postsCount %}
{% include "postslist.njk" %}

